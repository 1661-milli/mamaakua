<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mama Akua's Kitchen</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@400;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Lato', sans-serif;
    background: #1a0a00;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .header {
    text-align: center;
    margin-bottom: 16px;
  }
  .header h1 {
    font-family: 'Playfair Display', serif;
    color: #f5a623;
    font-size: 1.6rem;
  }
  .header p {
    color: #c8a87a;
    font-size: 0.85rem;
    margin-top: 4px;
  }
  .chat-box {
    width: 100%;
    max-width: 480px;
    background: #2a1500;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    height: 70vh;
  }
  .chat-top {
    background: #f5a623;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .avatar {
    width: 40px;
    height: 40px;
    background: #1a0a00;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
  }
  .chat-top-info h2 {
    font-family: 'Playfair Display', serif;
    color: #1a0a00;
    font-size: 1rem;
  }
  .chat-top-info p {
    color: #5a2d00;
    font-size: 0.75rem;
  }
  .messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .msg {
    max-width: 80%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 0.88rem;
    line-height: 1.5;
    animation: fadeIn 0.3s ease;
  }
  .msg.bot {
    background: #3d1f00;
    color: #f0d9b5;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .msg.user {
    background: #f5a623;
    color: #1a0a00;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
    font-weight: 700;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .quick-replies {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0 16px 12px;
  }
  .qr {
    background: transparent;
    border: 1.5px solid #f5a623;
    color: #f5a623;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: 'Lato', sans-serif;
    transition: all 0.2s;
  }
  .qr:hover, .qr:active {
    background: #f5a623;
    color: #1a0a00;
  }
  .input-area {
    display: flex;
    padding: 12px 16px;
    gap: 8px;
    border-top: 1px solid #3d1f00;
  }
  .input-area input {
    flex: 1;
    background: #3d1f00;
    border: none;
    border-radius: 24px;
    padding: 10px 16px;
    color: #f0d9b5;
    font-size: 0.88rem;
    font-family: 'Lato', sans-serif;
    outline: none;
  }
  .input-area input::placeholder { color: #7a5c3a; }
  .input-area button {
    background: #f5a623;
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    font-size: 1.1rem;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .input-area button:active { transform: scale(0.9); }
  .typing {
    display: flex;
    gap: 4px;
    padding: 10px 14px;
    background: #3d1f00;
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    align-self: flex-start;
    width: fit-content;
  }
  .typing span {
    width: 7px; height: 7px;
    background: #f5a623;
    border-radius: 50%;
    animation: bounce 1s infinite;
  }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
  }
</style>
</head>
<body>
<div class="header">
  <h1>🍲 Mama Akua's Kitchen</h1>
  <p>Authentic Ghanaian Home Cooking</p>
</div>
<div class="chat-box">
  <div class="chat-top">
    <div class="avatar">🍲</div>
    <div class="chat-top-info">
      <h2>Mama Akua</h2>
      <p>🟢 Online — replies instantly</p>
    </div>
  </div>
  <div class="messages" id="messages"></div>
  <div class="quick-replies" id="quickReplies"></div>
  <div class="input-area">
    <input type="text" id="userInput" placeholder="Type a message..." />
    <button onclick="sendMessage()">➤</button>
  </div>
</div>

<script>
const responses = {
  menu: {
    keywords: ['menu','food','eat','dishes','serve','offer','what do you have'],
    reply: `Our menu today 🍽️:\n\n🥘 Fufu & Light Soup — GH₵ 35\n🍛 Jollof Rice & Chicken — GH₵ 40\n🫕 Banku & Tilapia — GH₵ 45\n🍲 Waakye with extras — GH₵ 30\n🥗 Garden Egg Stew — GH₵ 25\n\nAll meals are freshly prepared daily! 😊`,
    quick: ['Reserve a table','Opening hours','Location','Order now']
  },
  hours: {
    keywords: ['hours','open','close','time','when'],
    reply: `⏰ We are open:\n\nMon – Fri: 7am – 9pm\nSat – Sun: 8am – 10pm\n\nCome early — our Fufu sells out fast! 😄`,
    quick: ['See menu','Reserve a table','Location']
  },
  location: {
    keywords: ['location','where','address','find','directions'],
    reply: `📍 Find us at:\n\nMama Akua's Kitchen\n14 Osu High Street, Accra\nNear the Total Fuel Station\n\nFree parking available! 🚗`,
    quick: ['See menu','Opening hours','Reserve a table']
  },
  reserve: {
    keywords: ['reserve','book','reservation','table','booking'],
    reply: `🍽️ To reserve a table, please call or WhatsApp us:\n\n📞 +233 24 000 0000\n\nTell us your name, date, time and number of guests. We'll confirm within 5 minutes! ✅`,
    quick: ['See menu','Opening hours','Location']
  },
  order: {
    keywords: ['order','delivery','deliver','buy'],
    reply: `🛵 We offer delivery within Osu & Labone!\n\nCall or WhatsApp to order:\n📞 +233 24 000 0000\n\nDelivery time: 30–45 mins ⏱️\nMinimum order: GH₵ 50`,
    quick: ['See menu','Reserve a table','Location']
  },
  greeting: {
    keywords: ['hi','hello','hey','good morning','good afternoon','good evening','start'],
    reply: `Akwaaba! 🙏 Welcome to Mama Akua's Kitchen!\n\nI'm here to help you with our menu, reservations, location and orders.\n\nHow can I help you today? 😊`,
    quick: ['See menu','Opening hours','Location','Reserve a table']
  }
};

const fallback = `I didn't quite catch that 😊\n\nI can help you with:\n• Our menu & prices\n• Opening hours\n• Location & directions\n• Table reservations\n• Delivery orders`;
const fallbackQuick = ['See menu','Opening hours','Location','Reserve a table'];

function addMessage(text, sender) {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = `msg ${sender}`;
  div.innerText = text;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function showTyping() {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'typing';
  div.id = 'typing';
  div.innerHTML = '<span></span><span></span><span></span>';
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing');
  if (t) t.remove();
}

function setQuickReplies(options) {
  const qr = document.getElementById('quickReplies');
  qr.innerHTML = '';
  options.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'qr';
    btn.innerText = opt;
    btn.onclick = () => handleInput(opt);
    qr.appendChild(btn);
  });
}

function getBotResponse(input) {
  const lower = input.toLowerCase();
  for (const key in responses) {
    const r = responses[key];
    if (r.keywords.some(k => lower.includes(k))) {
      return r;
    }
  }
  return { reply: fallback, quick: fallbackQuick };
}

function handleInput(text) {
  addMessage(text, 'user');
  setQuickReplies([]);
  showTyping();
  setTimeout(() => {
    removeTyping();
    const res = getBotResponse(text);
    addMessage(res.reply, 'bot');
    setQuickReplies(res.quick);
  }, 900);
}

function sendMessage() {
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  handleInput(text);
}

document.getElementById('userInput').addEventListener('keypress', e => {
  if (e.key === 'Enter') sendMessage();
});

// Welcome message
setTimeout(() => {
  const res = getBotResponse('hello');
  addMessage(res.reply, 'bot');
  setQuickReplies(res.quick);
}, 500);
</script>
</body>
</html>
